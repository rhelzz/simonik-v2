# =====================================================================
# SIMONIK V2 — contoh Environment Variables untuk Dokploy (PRODUCTION)
# Copy isi ini ke tab "Environment" service Dokploy, lalu sesuaikan.
# JANGAN commit nilai asli (APP_KEY, password DB) ke git.
# =====================================================================

APP_NAME="Simonik V2"
APP_ENV=production
# Generate sekali di lokal: `php artisan key:generate --show`
APP_KEY=base64:GANTI_DENGAN_KEY_ASLI
APP_DEBUG=false
# Domain produksi (harus https kalau SSL aktif)
APP_URL=https://simonik.domain-anda.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database (MySQL service terpisah di Dokploy) ---
# DB_HOST = nama service database di project Dokploy (bukan 127.0.0.1)
DB_CONNECTION=mysql
DB_HOST=simonik-db
DB_PORT=3306
DB_DATABASE=simonik_v2
DB_USERNAME=simonik
DB_PASSWORD=GANTI_PASSWORD_KUAT

# --- Session / Cache / Queue ---
# Tetap 'database' agar tidak butuh Redis. Migrasi sudah bikin tabelnya.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (sesuaikan dengan provider SMTP anda) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@domain-anda.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
