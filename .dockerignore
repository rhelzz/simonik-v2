# Dependencies & build output (rebuilt inside the image)
node_modules
vendor
public/build
public/hot

# Local env & secrets (provided via Dokploy Environment tab)
.env
.env.*
!.env.example

# VCS & tooling
.git
.gitignore
.github
.idea
.vscode

# Local database & logs
database/*.sqlite
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*

# Docs & tests (not needed at runtime)
docs
tests
phpunit.xml
.phpunit.result.cache

# Misc
README.md
*.md
!docs/DEPLOY-DOKPLOY.md
